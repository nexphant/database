{
    "name": "nexphant/database",
    "description": "Database layer for nexphant framework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "nexphant\\Database\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "nexphant/core": "^0.0",
        "nexphant/support": "^0.0"
    },
    "suggest": {
        "ext-mysqli": "For native MySQL async driver",
        "ext-pgsql": "For native PostgreSQL async driver and COPY support",
        "ext-sqlite3": "For SQLite support",
        "ext-pdo_sqlite": "For PDO SQLite driver",
        "ext-apcu": "For APCu cache driver",
        "ext-redis": "For Redis cache driver"
    }
}

